# Variabili d'ambiente richieste dal frontend (Vite)
# Copiare questo file in .env e inserire i valori reali (mai committare .env)

# URL del progetto Supabase (visibile nella dashboard Supabase > Settings > API)
VITE_SUPABASE_URL=https://<project-ref>.supabase.co

# Chiave pubblica (anon) del progetto Supabase — è safe lato client
VITE_SUPABASE_PUBLISHABLE_KEY=<supabase-anon-key>

# ----------------------------------------------------------------------------
# NOTA: VITE_GEMINI_API_KEY non esiste più.
# La chiave API Gemini è ora una secret server-side della Supabase Edge Function.
# Per configurarla eseguire (una volta sola, da terminale con Supabase CLI):
#
#   supabase secrets set GEMINI_API_KEY=<la-tua-chiave-gemini>
#
# La secret non viene mai inclusa nel bundle JavaScript pubblico.
# ----------------------------------------------------------------------------
